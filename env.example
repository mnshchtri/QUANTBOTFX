# QuantBotForex Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# OANDA API Configuration
# =============================================================================
# Get your API key from: https://www.oanda.com/account/login
OANDA_API_KEY=5d8fa14f91b6b0004929c07409dd9000-087ffb0d480ffdb7f1fced84eebb362a
OANDA_ACCOUNT_ID=101-001-30612983-001
OANDA_BASE_URL=https://api-fxpractice.oanda.com

# =============================================================================
# Application Settings
# =============================================================================
APP_ENVIRONMENT=development  # development, staging, production
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=your_secret_key_here_change_this_in_production

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL=sqlite:///./quantbot_forex.db
# For PostgreSQL: postgresql://user:password@localhost/quantbot_forex
# For MySQL: mysql://user:password@localhost/quantbot_forex

# =============================================================================
# Server Configuration
# =============================================================================
HOST=0.0.0.0
PORT=8000
WORKERS=4

# =============================================================================
# Frontend Configuration
# =============================================================================
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Trading Configuration
# =============================================================================
DEFAULT_INSTRUMENT=GBP_JPY
DEFAULT_TIMEFRAME=M15
MAX_POSITION_SIZE=10000
RISK_PERCENTAGE=2.0

# =============================================================================
# AI & Machine Learning
# =============================================================================
MODEL_PATH=./models/
MODEL_VERSION=1.0.0
FEATURE_WINDOW=50
PREDICTION_HORIZON=5

# =============================================================================
# Risk Management
# =============================================================================
MAX_DRAWDOWN=10.0
STOP_LOSS=2.0
TAKE_PROFIT=4.0
MAX_TRADES_PER_DAY=10

# =============================================================================
# Monitoring & Metrics
# =============================================================================
METRICS_ENABLED=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30

# =============================================================================
# Development Settings
# =============================================================================
MOCK_DATA=true
HOT_RELOAD=true
ENABLE_DEBUG_TOOLBAR=false

# =============================================================================
# Production Settings
# =============================================================================
SSL_ENABLED=false
RATE_LIMITING=true
MAX_REQUESTS_PER_MINUTE=1000
